# Monorepo ignores for KindKart

# Dependencies
**/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build and cache outputs
**/.next/
**/.next-build/
**/.next-build-*/
**/out/
**/dist/
**/build/
**/coverage/
**/.cache/
**/.turbo/

# TypeScript
**/*.tsbuildinfo

# Environment and secrets
**/.env
**/.env.*
!**/.env.example
!**/env.example
!**/.env.local.example

# Runtime data
kindkart-backend/data/*.db
kindkart-backend/data/*.db-*
kindkart-backend/data/*.sqlite
kindkart-backend/data/*.sqlite-*

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Editor and OS
.DS_Store
Thumbs.db
.idea/
.vscode/*.code-workspace

# Hosting and deployment metadata
**/.vercel/
